// Prisma schema - 雨止工作室项目展示系统

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// 用户表
model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  name         String
  nickname     String?
  avatar       String?
  role         String        @default("user")
  bio          String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sessions     Session[]
  messages     Message[]
  notifications Notification[]
}

// 会话表
model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// 项目表
model Project {
  id          String    @id @default(cuid())
  title       String
  description String
  coverImage  String?
  videoUrl    String?
  videoBvid   String?
  githubUrl   String?
  demoUrl     String?
  techStack   String
  featured    Boolean   @default(false)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  messages    Message[]
}

// 博客文章
model Blog {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String
  excerpt     String?
  coverImage  String?
  tags        String
  category    String?
  published   Boolean   @default(false)
  viewCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  messages    Message[]
}

// 时间线事件
model Timeline {
  id        String   @id @default(cuid())
  title     String
  content   String
  date      String
  type      String
  icon      String?
  link      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// 关于信息
model About {
  id        String   @id @default("about")
  name      String
  nickname  String?
  teamName  String?
  bio       String
  avatar    String?
  email     String?
  github    String?
  bilibili  String?
  twitter   String?
  website   String?
  techStack String?
  updatedAt DateTime @updatedAt
}

// 留言/评论
model Message {
  id         String    @id @default(cuid())
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  projectId  String?
  project    Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  blogId     String?
  blog       Blog?     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  guestName  String?
  guestEmail String?
  guestPhone String?   // 用于通知游客
  content    String
  parentId   String?   // 回复的留言 ID
  parent     Message?  @relation("MessageReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Message[] @relation("MessageReplies")
  ip         String?
  location   String?
  createdAt  DateTime  @default(now())
  notifications Notification[]
}

// 通知
model Notification {
  id          String   @id @default(cuid())
  userId      String   // 接收通知的用户
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // reply, system, etc.
  title       String
  content     String
  messageId   String?  // 相关留言 ID
  message     Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  fromUserId  String?  // 发送者用户 ID
  fromName    String?  // 发送者名称（游客回复时使用）
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}
